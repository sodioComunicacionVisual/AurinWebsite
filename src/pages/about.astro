---
import { getLangFromUrl, translations } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import { UsBanner, MainImage, UnexploredPaths, LongCards, OurStory, CollaborativeDesign, Alliances } from '@/blocks/about';
import DynamicProjects from '@/components/projects/DynamicProjects.astro';
import Footer from '@/components/layout/Footer.astro';
import { SITE } from '@/config/site';
import type { AboutPageStructuredData } from '@/types/seo';

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

// SEO optimizado para LLMs y motores de búsqueda
const seoTitle = t.about.seo.title;
const seoDescription = t.about.seo.description;
const seoKeywords = t.about.seo.keywords;

// Datos estructurados para SEO (Schema.org)
const structuredData: AboutPageStructuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
    "logo": SITE.logoUrl,
    "description": t.about.structuredData.description,
    "foundingDate": "2020",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Aldea Creativa",
      "addressCountry": "MX"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "email": SITE.contactEmail,
      "contactType": "customer service",
      "areaServed": "MX",
      "availableLanguage": currentLang === 'en' ? "English" : "Spanish"
    },
    "sameAs": SITE.sameAs,
    "knowsAbout": t.about.structuredData.knowsAbout,
    "areaServed": "MX",
    "serviceType": t.about.structuredData.serviceTypes
  }
};

// Selectores CSS para contenido speakable (optimización de voz)
const speakable = [".us-banner", ".unexplored-paths", ".our-story", ".collaborative-design"];
---

<Layout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={`${SITE.url}/about`}
  ogImage={SITE.logoUrl}
>
  <Header />
  <main id="main-content">
    <UsBanner />
    <MainImage />
    <UnexploredPaths />
    <LongCards />
    <OurStory />
    <CollaborativeDesign />
    <Alliances />
    <DynamicProjects />
  </main>
  <Footer />
</Layout>

<style>
  main {
    width: 100%;
    margin: 0 auto;
  }
</style>
