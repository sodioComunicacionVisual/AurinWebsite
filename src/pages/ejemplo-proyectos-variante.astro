---
// EJEMPLO DE USO: Strip de proyectos con 4 columnas y sin chips
// Este archivo demuestra cómo integrar la variante four-column en una página

import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Vignette from '@/components/ui/Vignette.astro';
import DynamicProjects from '@/components/projects/DynamicProjects.astro';
import StickyFooter from '@/components/layout/StickyFooter.astro';
---

<Layout
  title="Ejemplo - Variante 4 Columnas"
  description="Página de ejemplo mostrando la strip de proyectos con 4 columnas sin chips"
>
  <Vignette intensity="medium" />
  <Header />
  
  <main style="padding-top: 100px;">
    <!-- 
      Variante four-column: usa DynamicProjects con props específicas
      - maxProjects={4}: muestra 4 proyectos aleatorios
      - showChips={false}: oculta los chips de servicios
      - variant="four-column": activa el grid de 4 columnas en desktop
    -->
    <DynamicProjects maxProjects={4} showChips={false} variant="four-column" />
  </main>
  
  <StickyFooter />
</Layout>

<style>
  main {
    width: 100%;
    min-height: 100vh;
  }
</style>
