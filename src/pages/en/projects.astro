---
import { getLangFromUrl, translations } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Introduction from '@/blocks/projects/Introduction/Introduction.astro';
import ProjectsGrid from '@/components/projects/ProjectsGrid.astro';
import FilterPills from '@/components/ui/FilterPills.astro';
import CtaBanner from '@/components/layout/CtaBanner.astro';
import { SITE } from '@/config/site';
import type { CollectionPageStructuredData } from '@/types/seo';

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

// SEO optimized for LLMs and search engines
const seoTitle = t.projects.seo.title;
const seoDescription = t.projects.seo.description;
const seoKeywords = t.projects.seo.keywords;

// Datos estructurados para SEO (Schema.org)
const structuredData: CollectionPageStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": currentLang === 'es' ? "Portfolio de Proyectos - Aurin" : "Project Portfolio - Aurin",
  "description": seoDescription,
  "url": currentLang === 'es' ? `${SITE.url}/projects` : `${SITE.url}/en/projects`,
  "inLanguage": currentLang === 'es' ? "es-MX" : "en-US",
  "mainEntity": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
    "logo": SITE.logoUrl,
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Design Project Portfolio",
      "itemListElement": [
        {
          "@type": "CreativeWork",
          "name": t.projects.projectTitles["proyecto-innovador-1"],
          "description": "Branding, UI/UX and web development project",
          "creator": {
            "@type": "Organization",
            "name": SITE.name
          },
          "keywords": [t.projects.projectTags["Branding"], t.projects.projectTags["UI/UX"], t.projects.projectTags["Web"]]
        },
        {
          "@type": "CreativeWork",
          "name": t.projects.projectTitles["transformacion-digital"],
          "description": "Development and digital strategy project",
          "creator": {
            "@type": "Organization",
            "name": SITE.name
          },
          "keywords": [t.projects.projectTags["Desarrollo"], t.projects.projectTags["Estrategia"]]
        },
        {
          "@type": "CreativeWork",
          "name": t.projects.projectTitles["experiencia-usuario"],
          "description": "UX research and design project",
          "creator": {
            "@type": "Organization",
            "name": SITE.name
          },
          "keywords": [t.projects.projectTags["UX Research"], t.projects.projectTags["Design"]]
        }
      ]
    }
  }
};

// CSS selectors for speakable content (voice optimization)
const speakable = [".projects-introduction", ".projects-strip", ".project-card"];

// Canonical URL based on language
const canonicalUrl = currentLang === 'es' ? `${SITE.url}/projects` : `${SITE.url}/en/projects`;
---

<Layout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={canonicalUrl}
  ogImage={SITE.logoUrl}
>
  <Header />
  
  <main id="main-content" class="proyectos-page">
    <!-- Introduction Section -->
    <Introduction />

    <!-- Projects Grid - Automatically fetches and displays all projects from Payload CMS -->
    <section class="projects-section">
      <div class="projects-container">
        <!-- Filter Pills -->
        <FilterPills />

        <!-- Projects Grid -->
        <ProjectsGrid />
      </div>
    </section>

    <!-- Call to Action -->
    <CtaBanner />
  </main>
  
  <Footer />
</Layout>

<style>
  .proyectos-page {
    width: 100%;
    min-height: 100vh;
    padding-top: 80px;
  }

  /* Projects Section */
  .projects-section {
    width: 100%;
    padding: 60px 0;
  }

  .projects-container {
    max-width: var(--maxWidth);
    margin: 0 auto;
    padding: 0 100px;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .projects-container {
      padding: 0 60px;
    }
  }

  @media (max-width: 968px) {
    .projects-container {
      padding: 0 40px;
    }

    .projects-section {
      padding: 40px 0;
    }
  }

  @media (max-width: 768px) {
    .proyectos-page {
      padding-top: 60px;
    }

    .projects-container {
      padding: 0 30px;
    }
  }

  @media (max-width: 640px) {
    .projects-container {
      padding: 0 20px;
    }

    .projects-section {
      padding: 30px 0;
    }
  }
</style>
