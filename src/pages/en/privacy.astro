---
import { getLangFromUrl, translations } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CtaBanner from '@/components/layout/CtaBanner.astro';
import { Privacy } from '@/blocks/shared';
import Vignette from '@/components/ui/Vignette.astro';

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang].privacy;
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  keywords={t.seo.keywords}
>
  <Vignette intensity="medium" />
  <Header />

  <main id="main-content">
    <Privacy lang={currentLang} />
    <CtaBanner />
  </main>

  <Footer />
</Layout>
