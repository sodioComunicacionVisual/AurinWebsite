---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import StickyFooter from '../../components/StickyFooter.astro';
import MainCat from '../../components/MainCat.astro';
import Privacy from '../../blocks/shared/Privacy/Privacy.astro';
import InteractiveBackground from '../../components/InteractiveBackground.astro';
import Vignette from '../../components/Vignette.astro';
import { getLangFromUrl } from '../../i18n/utils';
import { translations } from '../../i18n/translations';

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang].privacy;
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  keywords={t.seo.keywords}
>
  <InteractiveBackground />
  <Vignette intensity="medium" />
  <Header />

  <main>
    <Privacy lang={currentLang} />
    <MainCat />
  </main>

  <StickyFooter />
</Layout>
