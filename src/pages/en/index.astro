---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import MegaMenu from '../../components/MegaMenu.astro';
import InteractiveBackground from '../../components/InteractiveBackground.astro';
import Vignette from '../../components/Vignette.astro';
import Banner from '../../blocks/home/HomeBanner/Banner.astro';
import Descripcion from '../../blocks/home/Descripcion/Descripcion.astro';
import ExpertosUsuarios from '../../blocks/home/ExpertosUsuarios/ExpertosUsuarios.astro';
import EnterpriseMarquee from '../../blocks/home/EnterpriseMarquee/EnterpriseMarquee.astro';
import Especialidades from '../../blocks/home/Especialidades/Especialidades.astro';
import MainCat from '../../components/MainCat.astro';
import HerramientasVariant from '../../blocks/shared/HerramientasVariant/HerramientasVariant.astro';
import DynamicProjects from '../../components/DynamicProjects.astro';
import StickyFooter from '../../components/StickyFooter.astro';
import { translations } from '../../i18n/translations.js';

// Get English translations
const t = translations.en;

// SEO optimized for LLMs and search engines
const seoTitle = t.seo.title;
const seoDescription = t.seo.description;
const seoKeywords = t.seo.keywords;

// Structured data for SEO (Schema.org)
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Aurin",
  "url": "https://aurin.mx",
  "logo": "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/aurinWhiteLogo.webp",
  "description": seoDescription,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Aldea Creativa",
    "addressCountry": "MX"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hey@aurin.mx",
    "contactType": "customer service"
  },
  "sameAs": [
    "https://aldeacreativa.mx/"
  ],
  "areaServed": "MX",
  "serviceType": t.structuredData.serviceTypes
};

// CSS selectors for speakable content (voice optimization)
const speakable = [".banner-content", ".descripcion-principal", ".especialidades-section"];

---

<Layout 
	title={seoTitle}
	description={seoDescription}
	keywords={seoKeywords}
	structuredData={structuredData}
	speakable={speakable}
	canonical="https://aurin.mx/en/"
	ogImage="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/aurinWhiteLogo.webp"
>
	<InteractiveBackground />
	<Vignette intensity="medium" />
	<Header />
	<MegaMenu />
	<main>
	
		<Banner/>
		<Descripcion />
		
		<EnterpriseMarquee />
		
		
		<ExpertosUsuarios />

		<Especialidades />
		
		
		<MainCat/>

		<HerramientasVariant />

		<DynamicProjects maxProjects={4} showChips={false} variant="four-column" />

		<StickyFooter />

	</main>
</Layout>
