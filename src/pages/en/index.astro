---
import { translations } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import MegaMenu from '@/components/layout/MegaMenu.astro';
import Vignette from '@/components/ui/Vignette.astro';
import Hero from '@/blocks/home/Hero/Hero.astro';
import Description from '@/blocks/home/Description/Description.astro';
import UserExperts from '@/blocks/home/UserExperts/UserExperts.astro';
import EnterpriseMarquee from '@/blocks/home/EnterpriseMarquee/EnterpriseMarquee.astro';
import Specialties from '@/blocks/home/Specialties/Specialties.astro';
import CtaBanner from '@/components/layout/CtaBanner.astro';
import ToolsVariant from '@/blocks/shared/ToolsVariant/ToolsVariant.astro';
import DynamicProjects from '@/components/projects/DynamicProjects.astro';
import StickyFooter from '@/components/layout/StickyFooter.astro';

// Get English translations
const t = translations.en;

// SEO optimized for LLMs and search engines
const seoTitle = t.seo.title;
const seoDescription = t.seo.description;
const seoKeywords = t.seo.keywords;

// Structured data for SEO (Schema.org)
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Aurin",
  "url": "https://aurin.mx",
  "logo": "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/aurinWhiteLogo.webp",
  "description": seoDescription,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Aldea Creativa",
    "addressCountry": "MX"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hey@aurin.mx",
    "contactType": "customer service"
  },
  "sameAs": [
    "https://aldeacreativa.mx/"
  ],
  "areaServed": "MX",
  "serviceType": t.structuredData.serviceTypes
};

// CSS selectors for speakable content (voice optimization)
const speakable = [".banner-content", ".description-main", ".specialties-section"];

---

<Layout 
	title={seoTitle}
	description={seoDescription}
	keywords={seoKeywords}
	structuredData={structuredData}
	speakable={speakable}
	canonical="https://aurin.mx/en/"
	ogImage="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/aurinWhiteLogo.webp"
>
	<Vignette intensity="medium" />
	<Header />
	<MegaMenu />
	<main>
	
		<Hero/>
		<Description />
		
		<EnterpriseMarquee />
		
		
		<UserExperts />

		<Specialties />
		
		
		<CtaBanner/>

		<ToolsVariant />

		<DynamicProjects maxProjects={4} showChips={false} variant="four-column" />

		<StickyFooter />

	</main>
</Layout>
