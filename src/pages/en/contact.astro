---
import { getLangFromUrl, translations } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Form from '@/blocks/shared/Contact/Form.astro';
import Toast from '@/components/ui/Toast.astro';
import { SITE } from '@/config/site';
import type { ContactPageStructuredData } from '@/types/seo';

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

// SEO optimized for LLMs and search engines
const seoTitle = t.contact.seo.title;
const seoDescription = t.contact.seo.description;
const seoKeywords = t.contact.seo.keywords;

// Structured data for SEO (Schema.org)
const structuredData: ContactPageStructuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "mainEntity": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
    "logo": SITE.logoUrl,
    "contactPoint": {
      "@type": "ContactPoint",
      "email": SITE.contactEmail,
      "contactType": "customer service",
      "areaServed": "MX",
      "availableLanguage": ["Spanish", "English"]
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Aldea Creativa",
      "addressCountry": "MX"
    }
  }
};

// CSS selectors for speakable content (voice optimization)
const speakable = [".contact-form", ".contact-info"];
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={`${SITE.url}/en/contact`}
  ogImage={SITE.logoUrl}
>
  <Header />
  <main id="main-content">
    <Form />
  </main>
  <Footer />
  <Toast />
</Layout>

<style>
  body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
  }

  main {
    min-height: 100vh;
    padding-top: 88px;
  }
</style>
