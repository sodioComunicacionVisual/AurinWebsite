---
import type { OrganizationStructuredData } from "@/types/seo";
import { SITE } from "@/config/site";
import { translations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import {
  Hero,
  OurVision,
  SliderClients,
  UserExperts,
  Specialties,
} from "@/blocks/home";
import ToolsSuite from "@/blocks/shared/ToolsVariant/ToolsVariant.astro";
import Header from "@/components/layout/Header.astro";
import MegaMenu from "@/components/layout/MegaMenu.astro";
import Banner from "@/components/layout/CtaBanner.astro";
import Footer from "@/components/layout/Footer.astro";
import Projects from "@/components/projects/DynamicProjects.astro";

const t = translations.es;

const seoTitle = t.seo.title;
const seoDescription = t.seo.description;
const seoKeywords = t.seo.keywords;

const structuredData: OrganizationStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  logo: SITE.logoUrl,
  description: seoDescription,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Aldea Creativa",
    addressCountry: "MX",
  },
  contactPoint: {
    "@type": "ContactPoint",
    email: SITE.contactEmail,
    contactType: "customer service",
  },
  sameAs: SITE.sameAs,
  areaServed: "MX",
  serviceType: t.structuredData.serviceTypes,
};

// (Voice optimization)
const speakable = [
  ".banner-content",
  ".description-main",
  ".specialties-section",
];
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={SITE.url}
  ogImage={SITE.logoUrl}
>
  <Header />
  <MegaMenu />
  <main id="main-content">
    <Hero />
    <OurVision />
    <SliderClients />
    <UserExperts />
    <Specialties />
    <ToolsSuite />
    <Projects maxProjects={4} showChips={false} variant="four-column" />
    <Banner />
    <Footer />
  </main>
</Layout>
