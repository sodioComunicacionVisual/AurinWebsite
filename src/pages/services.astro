---
import { getLangFromUrl, translations } from '@/i18n';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { ServicesBanner, Services, ToolsScrollStory } from '@/blocks/services';
import CtaBanner from '@/components/layout/CtaBanner.astro';
import DynamicProjects from '@/components/projects/DynamicProjects.astro';
import { SITE } from '@/config/site';
import type { ServiceStructuredData } from '@/types/seo';

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

// SEO optimizado para LLMs y motores de búsqueda
const seoTitle = t.services.seo.title;
const seoDescription = t.services.seo.description;
const seoKeywords = t.services.seo.keywords;

// Datos estructurados para SEO (Schema.org)
const structuredData: ServiceStructuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Servicios de Comunicación Visual y Diseño",
  "provider": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
    "logo": SITE.logoUrl,
    "contactPoint": {
      "@type": "ContactPoint",
      "email": SITE.contactEmail,
      "contactType": "customer service"
    }
  },
  "areaServed": "MX",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Diseño y Comunicación Visual",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Diseño Gráfico",
          "description": "Servicios profesionales de diseño gráfico para medios digitales e impresos"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Branding e Identidad Corporativa",
          "description": "Desarrollo de marca, identidad visual y estrategia de branding"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Diseño UX/UI",
          "description": "Diseño de experiencia de usuario e interfaces digitales"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Estrategia Digital",
          "description": "Consultoría y estrategia de comunicación digital"
        }
      }
    ]
  }
};

// Selectores CSS para contenido speakable (optimización de voz)
const speakable = [".services-banner", ".services-list", ".ux-description"];

---

<Layout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={`${SITE.url}/services`}
  ogImage={SITE.logoUrl}
>
  <Header />
  <main id="main-content">
    <ServicesBanner />
    <Services />
    <ToolsScrollStory />
    <DynamicProjects />
    <CtaBanner />
  </main>
  <Footer />
</Layout>