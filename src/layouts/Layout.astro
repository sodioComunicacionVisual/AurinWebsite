---
import '../styles/global.css';
import MegaMenu from '../components/MegaMenu.astro';
import AdvancedSEO from '../blocks/shared/SEO/AdvancedSEO.astro';
{/* import PageLoader from '../components/PageLoader.astro'; */}
import ChatbotContainer from '../blocks/shared/Chatbot/ChatbotContainer.astro';
import SpotlightCursorContainer from '../components/SpotlightCursorContainer.astro';
import Vignette from '../components/Vignette.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
	title: string;
	description?: string;
	canonical?: string;
	ogImage?: string;
	ogType?: string;
	structuredData?: object;
	speakable?: string[];
	keywords?: string;
	author?: string;
	twitterCard?: string;
	vignetteIntensity?: 'light' | 'medium' | 'strong';
	vignetteColor?: string;
	showVignette?: boolean;
}

const { 
	title,
	description,
	canonical,
	ogImage,
	ogType,
	structuredData,
	speakable,
	keywords,
	author,
	twitterCard,
	vignetteIntensity = 'medium',
	vignetteColor,
	showVignette = false
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		
		<!-- Browser toolbar color customization -->
		<meta name="theme-color" content="#d0df00" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

		<!-- Favicon configuration -->
		<link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
		
		<!-- Web App Manifest -->
		<link rel="manifest" href="/favicon/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts — non-blocking load -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Titillium+Web:ital,wght@0,200;0,300;0,400;0,600;0,700;0,900;1,200;1,300;1,400;1,600;1,700&family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Titillium+Web:ital,wght@0,200;0,300;0,400;0,600;0,700;0,900;1,200;1,300;1,400;1,600;1,700&family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Titillium+Web:ital,wght@0,200;0,300;0,400;0,600;0,700;0,900;1,200;1,300;1,400;1,600;1,700&family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap" /></noscript>

		<!-- Prefetch critical resources -->
		<link rel="prefetch" href="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Avatar_2%404x.webp" as="image" />
		
		<!-- SEO Avanzado -->
		<AdvancedSEO 
			title={title}
			description={description}
			canonical={canonical}
			ogImage={ogImage}
			ogType={ogType}
			structuredData={structuredData}
			speakable={speakable}
			keywords={keywords}
			author={author}
			twitterCard={twitterCard}
		/>
	</head>
	<body>
		<SpotlightCursorContainer />
		{/* <PageLoader /> */}
		<MegaMenu />
		<slot />
		{showVignette && (
			<Vignette 
				intensity={vignetteIntensity}
				color={vignetteColor}
			/>
		)}
		<ChatbotContainer />
		<SpeedInsights />
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	
	html {
		font-family: 'Titillium Web', -apple-system, BlinkMacSystemFont, sans-serif;
		background: #000000;
		overflow-x: hidden;
	}

	body {
		margin: 0;
		padding: 0;
		overflow-x: hidden;
		width: 100%;
	}
	
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
</style>
