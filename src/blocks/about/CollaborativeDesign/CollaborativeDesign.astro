---
import { getLangFromUrl, translations } from '@/i18n';
import SecondaryButton from '@/components/ui/SecondaryButton.astro';

import styles from './CollaborativeDesign.module.css';

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles['collaborative-design']}>
    <div class={styles['design-container']}>
        <div class={styles['content-column']}>
            <div class={styles['text-card']}>
                <div class={styles['text-content']}>
                    <h2 class={styles['heading-2']}>{t.about.collaborativeDesign.heading}</h2>
                </div>
                <p class={styles['body-1']}>{t.about.collaborativeDesign.description}</p>
                <div class={styles['button-group']}>
                    <SecondaryButton
                        text={t.about.collaborativeDesign.buttonText}
                        href="https://aldeacreativa.com"
                        target="_blank"
                    />
                </div>
            </div>
        </div>
        <div class={styles['image-column']}>
            <div class={styles['image-wrapper']}>
                <img
                    src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/DisenoColaboracionInnovacion.webp"
                    alt={t.about.collaborativeDesign.imageAlt}
                    class="ukiyo"
                    loading="lazy"
                    data-u-speed="1.2"
                    data-u-scale="1.1"
                />
            </div>
        </div>
    </div>
</section>

<script>
  import Ukiyo from 'ukiyojs';
  
  // Initialize Ukiyo parallax effect when the DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new Ukiyo('.ukiyo', {
      speed: 1.2,
      scale: 1.1,
      wrapperClass: 'ukiyo-wrapper',
      willChange: true
    });
  });
</script>
