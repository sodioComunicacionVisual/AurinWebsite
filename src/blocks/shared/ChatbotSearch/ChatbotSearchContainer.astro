---
import { getLangFromUrl, translations } from '@/i18n';
import { ChatbotInterface } from './index';

const lang = getLangFromUrl(Astro.url);
const t = translations[lang].chatbotSearch;
---

<div class="chatbot-search-wrapper">
  <ChatbotInterface client:only="react" translations={t} />
</div>

<style>
  .chatbot-search-wrapper {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  @media (max-width: 768px) {
    .chatbot-search-wrapper {
      max-width: 100%;
      padding: 0;
    }
  }
</style>
