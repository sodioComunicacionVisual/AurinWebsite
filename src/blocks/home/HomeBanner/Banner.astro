---
import { getLangFromUrl } from "../../../i18n/utils.js";
import { translations } from "../../../i18n/translations.js";
import styles from "./Banner.module.css";
import BannerBackgroundEffectsContainer from "../../shared/Banner/BannerBackgroundEffectsContainer.astro";
import FloatingDustContainer from "../../shared/Banner/FloatingDustContainer.astro";
import ChatbotSearchContainer from "../../shared/ChatbotSearch/ChatbotSearchContainer.astro";

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.banner}>
  <div class={styles.bannerContainer}>
    <!-- Capa de fondo con efectos WebGL y textura -->
    <BannerBackgroundEffectsContainer />

    <!-- Floating dust particles -->
    <FloatingDustContainer />

    <!-- Contenido principal -->
    <div class={styles.content}>
      <div class={styles.contentInner}>
        <!-- Aurin Logo -->
        <div class={styles.logoContainer}>
          <div class={styles.logoTilt}>
            <img
              src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Header-logo.svg"
              alt="Aurin Logo"
              class={styles.logo}
              draggable="false"
            />
          </div>
        </div>

        <!-- Títulos -->
        <div class={styles.titles}>
          <h2>{t.banner.title1}</h2>
          <h2>{t.banner.title2}</h2>
        </div>

        <!-- Search Input -->
        <div class={styles.searchContainer}>
          <ChatbotSearchContainer />
        </div>
      </div>
    </div>
  </div>
</section>
