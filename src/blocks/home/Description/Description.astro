---
import { getLangFromUrl, translations } from '@/i18n';
import ScrollReveal from "@/components/animation/ScrollReveal.astro";

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class="description description-main">
  <div class="descriptionContainer">
    <!-- Left column -->
    <div class="leftColumn">
      <ScrollReveal
        text={t.homeDescription.mainHeading}
        tag="h2"
        textClass="mainHeadingText"
        baseOpacity={0.2}
        baseRotation={4}
        blurStrength={5}
        enableBlur={true}
      />

      <div class="contentText">
        <p class="description" style="color: var(--color-white);">
          {t.homeDescription.contentText}<br />
          <strong class="textHighlight"
            >{t.homeDescription.contentHighlight}</strong
          >
          {t.homeDescription.contentContinue}
        </p>
      </div>

      <div class="contrastTextWrapper">
        <p class="contrastText">
          {t.homeDescription.contrastText}
        </p>
      </div>
    </div>

  </div>
  <div class="svgAbsolute">
    <img
      src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/LightSVG.svg"
      alt=""
      class="svgElement"
    />
  </div>
</section>

<script>
  import { scroll, animate } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const smallText = document.querySelector(
      "[data-parallax-small]",
    ) as HTMLElement;
    const largeText = document.querySelector(
      "[data-parallax-large]",
    ) as HTMLElement;

    if (smallText) {
      scroll(animate(smallText, { y: [0, 40] }), {
        target: smallText,
        offset: ["start end", "end start"],
      });
    }

    if (largeText) {
      scroll(animate(largeText, { y: [0, -60] }), {
        target: largeText,
        offset: ["start end", "end start"],
      });
    }
  });
</script>

<style>
.description {
  position: relative;
  padding-top: var(--spacing-12);
  padding-bottom: var(--spacing-8);
  padding-inline: var(--section-padding-x);
  overflow: hidden;
}

.descriptionContainer {
  max-width: var(--maxWidth);
  margin: 0 auto;
  display: flex;
  align-items: flex-start;
}

/* Left column */
.leftColumn {
  width: 600px;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  gap: 50px;
  padding-top: var(--spacing-5);
  padding-bottom: var(--spacing-5);
}

.mainHeadingText {
  font-family: var(--font-family-display);
  font-size: 32px;
  line-height: 35px;
  font-weight: var(--font-weight-light);
  color: var(--color-yellow);
  margin: 0;
}

.contentText {
  align-self: stretch;
}

.contentText p {
  font-size: var(--font-size-xl);
}

.textHighlight {
  color: var(--color-yellow);
  font-weight: var(--font-weight-bold);
}

.contrastTextWrapper {
  width: 100%;
}

.contrastText {
  color: var(--color-yellow);
  font-family: var(--font-family-display);
  font-size: 48px;
  font-weight: var(--font-weight-light);
  line-height: 50px;
  margin: 0;
  word-wrap: break-word;
  overflow-wrap: break-word;
  hyphens: auto;
}

/* SVG — absolutely positioned, tracks end of text column at all widths.
   At ≤1830px (1600+2×115) the left edge is always 763px from the section left.
   On wider screens the centered container shifts right, so the formula adjusts:
   max( (viewport - 1830px) / 2 + 763px, 763px ) */
.svgAbsolute {
  position: absolute;
  left: max(calc((100% - 1830px) / 2 + 763px), 763px);
  top: 75px;
  right: var(--spacing-10);
  pointer-events: none;
}

.svgElement {
  display: block;
  width: 100%;
  height: auto;
  mix-blend-mode: plus-lighter;
}


/* Responsive */

/* Tablet angosto + desktop estrecho (1025–1279px):
   el SVG quedaría demasiado delgado, se oculta */
@media (max-width: 1279px) {
  .svgAbsolute {
    display: none;
  }
}

/* Tablet (≤1024px): columna de texto a ancho completo */
@media (max-width: 1024px) {
  .leftColumn {
    width: 100%;
    max-width: 100%;
    padding-top: 0;
    padding-bottom: 0;
  }
}

@media (max-width: 767px) {
  .description {
    padding-top: var(--spacing-10);
    padding-bottom: var(--spacing-8);
  }

  .leftColumn {
    gap: var(--spacing-8);
  }
}

@media (max-width: 480px) {
  .description {
    padding-top: var(--spacing-8);
    padding-bottom: var(--spacing-6);
  }

  .leftColumn {
    gap: var(--spacing-5);
  }

  .mainHeadingText {
    font-size: 24px;
    line-height: 28px;
  }

  .contrastText {
    font-size: 36px;
    line-height: 40px;
  }
}
</style>
