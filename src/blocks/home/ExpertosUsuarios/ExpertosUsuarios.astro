---
import { getLangFromUrl } from '../../../i18n/utils.js';
import { translations } from '../../../i18n/translations.js';
import styles from './ExpertosUsuarios.module.css';

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.expertosUsuarios}>
  <img
    src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Vector.svg"
    alt=""
    class={styles.vectorDecoration}
    aria-hidden="true"
  />
  <div class={styles.container}>
    <div class={styles.contentWrapper}>
      <!-- Left Column: Title -->
      <div class={styles.titleColumn}>
        <h2>
          <span>{t.expertosUsuarios.subtitle}</span>
          {t.expertosUsuarios.title}
        </h2>
      </div>

      <!-- Right Column: Description and CTA -->
      <div class={styles.contentColumn}>
        <p class={styles.description}>{t.expertosUsuarios.description}</p>

        <div class={styles.splitButton}>
          <a href="/nosotros" class={styles.splitButtonText}>
            {t.expertosUsuarios.buttonText}
          </a>
          <a href="/nosotros" class={styles.splitButtonIcon} aria-label="Ver más">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 17L17 5M17 5H8M17 5V14" stroke="#0A0A0A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
