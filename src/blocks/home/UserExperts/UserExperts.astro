---
import { getLangFromUrl, translations, getLocalizedUrl } from "@/i18n";
import MainButton from "@/components/ui/MainButton.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import styles from "./UserExperts.module.css";

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
const aboutUrl = getLocalizedUrl("/about", currentLang);
---

<section class={styles.section}>
  {/* Glow is a direct child of section so left:0 = true section left edge */}
  <img
    src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Vector.svg"
    alt=""
    class={styles.glow}
    aria-hidden="true"
  />

  <div class={styles.layout}>
    <div class={styles.titleBlock}>
      <SectionHeading
        lightText={t.userExperts.subtitle}
        highlightText={t.userExperts.title}
      />
    </div>

    <div class={styles.bodyBlock}>
      <p class={styles.bodyText}>{t.userExperts.description}</p>
      <MainButton text={t.userExperts.buttonText} href={aboutUrl} />
    </div>
  </div>
</section>
