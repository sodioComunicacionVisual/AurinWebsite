---
// Infinite Slider Marquee - Astro Island with Motion Dev
// Uses client:load for interactive animation

const LOGOS = [
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/AntojosSabores.svg", alt: "Antojos Sabores Logo", height: 80 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Galicia.svg", alt: "Galicia Logo", height: 72 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/InglesIndividual.svg", alt: "Inglés Individual Logo", height: 60 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Latiz.svg", alt: "Latiz Logo", height: 108 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/MexicoPacific.svg", alt: "Mexico Pacific Logo", height: 96 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Pinnacle.svg", alt: "Pinnacle Logo", height: 80 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/SinfonicadeMineria.svg", alt: "Sinfónica de Minería Logo", height: 96 },
  { src: "https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/TioFrancisco%20.svg", alt: "Tío Francisco Logo", height: 80 },
];
---

<section class="enterpriseMarquee">
  <div class="marqueeWrapper">
    <div class="marqueeContent">
      <!-- Slider section -->
      <div class="marqueeSlider" id="marquee-slider">
        <div class="sliderTrack" id="slider-track">
          {LOGOS.map((logo, index) => (
            <>
              <div class="logoItem">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  style={`height: calc(${logo.height}px * var(--logo-scale, 1))`}
                  width="auto"
                  draggable="false"
                />
              </div>
              {index < LOGOS.length - 1 && <div class="logoSeparator"></div>}
            </>
          ))}
          {LOGOS.map((logo, index) => (
            <>
              <div class="logoItem">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  style={`height: calc(${logo.height}px * var(--logo-scale, 1))`}
                  width="auto"
                  draggable="false"
                />
              </div>
              {index < LOGOS.length - 1 && <div class="logoSeparator"></div>}
            </>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>

.enterpriseMarquee {
  margin: 8rem 0;
  padding: 2rem 0;
  width: 100%;
  background-color: black;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4),
              0 4px 16px rgba(0, 0, 0, 0.2);
}

.marqueeWrapper {
  margin: 0 auto;
  max-width: var(--maxWidth);
  padding: 0 1.5rem;
}

.marqueeContent {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .marqueeContent {
    flex-direction: row;
    gap: 0;
  }
}

.marqueeText {
  flex-shrink: 0;
  text-align: center;
  max-width: 176px;
}

@media (min-width: 768px) {
  .marqueeText {
    text-align: right;
    border-right: 1px solid var(--color-gray-b);
    padding-right: 1.5rem;
  }
}

.marqueeText p {
  font-size: 0.875rem;
  color: var(--color-gray-a);
  font-family: var(--font-body);
}

.marqueeSlider {
  --logo-scale: 1.3;
  width: 100%;
  padding: 1.5rem 0;
  position: relative;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent, black 80px, black calc(100% - 80px), transparent);
  -webkit-mask-image: linear-gradient(to right, transparent, black 80px, black calc(100% - 80px), transparent);
}

@media (min-width: 768px) {
  .marqueeSlider {
    flex: 1;
  }
}

.sliderTrack {
  display: flex;
  align-items: center;
  gap: 56px;
  width: max-content;
  animation: scroll 30s linear infinite;
}

.logoSeparator {
  width: 1px;
  height: calc(34px * var(--logo-scale, 1));
  background-color: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.logoItem {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.logoItem img {
  filter: invert(1);
  opacity: 0.7;
  width: auto;
}
</style>
