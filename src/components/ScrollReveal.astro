---
interface Props {
  text: string;
  enableBlur?: boolean;
  baseOpacity?: number;
  baseRotation?: number;
  blurStrength?: number;
  containerClass?: string;
  textClass?: string;
  textStyle?: string;
  tag?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'p' | 'span';
}

const {
  text,
  containerClass = '',
  textClass = '',
  textStyle = '',
  tag = 'h2',
} = Astro.props;
---

<div class={containerClass}>
  {tag === 'h1' && <h1 class={textClass} style={textStyle}>{text}</h1>}
  {tag === 'h2' && <h2 class={textClass} style={textStyle}>{text}</h2>}
  {tag === 'h3' && <h3 class={textClass} style={textStyle}>{text}</h3>}
  {tag === 'h4' && <h4 class={textClass} style={textStyle}>{text}</h4>}
  {tag === 'h5' && <h5 class={textClass} style={textStyle}>{text}</h5>}
  {tag === 'h6' && <h6 class={textClass} style={textStyle}>{text}</h6>}
  {tag === 'p' && <p class={textClass} style={textStyle}>{text}</p>}
  {tag === 'span' && <span class={textClass} style={textStyle}>{text}</span>}
</div>