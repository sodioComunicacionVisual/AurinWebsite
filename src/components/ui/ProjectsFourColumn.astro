---
import SectionHeading from './SectionHeading.astro';
import ProjectCardNoChips from './ProjectCardNoChips.astro';
import ButtonIsland from './ButtonIsland.astro';
import { getLangFromUrl } from '../../i18n/utils.js';
import { translations } from '../../i18n/translations.js';
import { PayloadAPI, getProjectUrl, getImageUrl, type PayloadProject } from '../../lib/payload';
import styles from './ProjectsFourColumn.module.css';

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

// Fetch projects from Payload CMS
let projects: PayloadProject[] = [];
try {
  // Get all projects and select 4 random ones
  const allProjects = await PayloadAPI.getProjects(currentLang);

  // Shuffle array and take first 4 (Fisher-Yates shuffle)
  const shuffled = [...allProjects];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }

  projects = shuffled.slice(0, 4);
} catch (error) {
  console.error('Error fetching projects:', error);
  // Fallback to empty array if CMS is not available
  projects = [];
}
---

<section class={styles.projects}>
  <div class={styles.projectsContainer}>
    <!-- Header section -->
    <div class={styles.headerSection}>
      <SectionHeading
        lightText={t.projects.headingLight}
        highlightText={t.projects.headingHighlight}
      />
      
      <ButtonIsland
        text={t.projects.buttonText}
        href={currentLang === 'es' ? '/proyectos' : '/en/projects'}
        variant="primary"
      />
    </div>

    <!-- Projects grid - 4 columns -->
    <div class={styles.projectsGrid}>
      {projects.length > 0 ? (
        projects.map((project) => (
          <ProjectCardNoChips
            title={project.title}
            tags={[
              ...(project.category ? [project.category.name] : [])
            ]}
            image={getImageUrl(project.hero.bannerImage?.url) || 'https://placehold.co/800x600?text=No+Image'}
            href={getProjectUrl(project, currentLang)}
            services={project.hero.services || []}
            filters={project.projectFilters || []}
          />
        ))
      ) : (
        <!-- Fallback projects if CMS is not available -->
        <>
          <ProjectCardNoChips
            title="Galicia"
            tags={[t.projects.tags.uxui, t.projects.tags.frontBack]}
            image="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/ProjectGalicia.webp"
            href="/proyectos/galicia"
          />

          <ProjectCardNoChips
            title="Sinfonica de<br/>Minería"
            tags={[t.projects.tags.uxui, t.projects.tags.frontBack]}
            image="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/ProjectSinfonica.webp"
            href="/proyectos/sinfonica"
          />

          <ProjectCardNoChips
            title="SAI Derecho y economía"
            tags={[t.projects.tags.uxui, t.projects.tags.frontBack]}
            image="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/ProjectSai.webp"
            href="/proyectos/sai"
          />

          <ProjectCardNoChips
            title="Proyecto Extra"
            tags={[t.projects.tags.uxui]}
            image="https://placehold.co/800x600?text=Proyecto+4"
            href="/proyectos"
          />
        </>
      )}
    </div>
  </div>
</section>
