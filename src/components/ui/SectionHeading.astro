---
import styles from './SectionHeading.module.css';

interface Props {
  lightText: string;
  highlightText: string;
  tag?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
}

const { lightText, highlightText, tag = 'h2' } = Astro.props;
const Tag = tag;
---
<div class={styles.headingWrapper}>
  <Tag>
    <span>{lightText}</span>
    {highlightText}
  </Tag>
</div>
