---
import { ArrowUpRight } from "lucide-astro";
import styles from "./ButtonIsland.module.css";

interface Props {
  text?: string;
  type?: "button" | "submit" | "reset";
  onClick?: string;
  disabled?: boolean;
  class?: string;
  href?: string;
  variant?: "primary" | "secondary";
}

const {
  text = "Button",
  type = "button",
  onClick,
  disabled = false,
  class: className = "",
  href,
  variant = "primary",
} = Astro.props;

const cls = [
  styles.btn,
  variant === "secondary" && styles.btnSecondary,
  className,
]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a href={href} class={cls} data-animate-button>
      <span class={styles.btnText}>{text}</span>
      <span class={styles.btnIcon}>
        <ArrowUpRight size={26} strokeWidth={6} />
      </span>
    </a>
  ) : (
    <button
      type={type}
      onclick={onClick}
      disabled={disabled}
      class={cls}
      data-animate-button
    >
      <span class={styles.btnText}>{text}</span>
      <span class={styles.btnIcon}>
        <ArrowUpRight size={26} strokeWidth={6} />
      </span>
    </button>
  )
}

<script>
  function init() {
    const observer = new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            observer.unobserve(e.target);
          }
        }),
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    document
      .querySelectorAll("[data-animate-button]")
      .forEach((el) => observer.observe(el));
  }

  document.addEventListener("astro:page-load", init);
  // Fallback: astro:page-load puede disparar antes de que el module script se registre
  if (document.readyState !== "loading") init();
  else document.addEventListener("DOMContentLoaded", init);
</script>
