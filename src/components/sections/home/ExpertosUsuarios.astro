---
import MainButton from '../../ui/MainButton.astro';
import LampLight from '../../ui/LampLight.astro';
import ScrollReveal from '../../ui/ScrollReveal.astro';
import { getLangFromUrl } from '../../../i18n/utils.js';
import { translations } from '../../../i18n/translations.js';
import styles from './ExpertosUsuarios.module.css';
// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.expertosUsuarios}>
  <div class={styles.lampDecoration}>
    <LampLight lightColor="#D0DF00" intensity="medium" />
  </div>
  <div class={styles.container}>
    <div class={styles.contentWrapper}>
      <!-- Left Column: Title -->
      <div class={styles.titleColumn}>
        <h2 class="heading-5" style="color: var(--color-white); margin: 0;">{t.expertosUsuarios.subtitle}</h2>
        <ScrollReveal 
          text={t.expertosUsuarios.title}
          tag="h1"
          textClass="heading-5"
          textStyle="color: var(--color-yellow); margin: 0;"
          baseOpacity={0.7}
          baseRotation={2}
          blurStrength={2}
          enableBlur={true}
        />
      </div>

      <!-- Right Column: Description and CTA -->
      <div class={styles.contentColumn}>
        <div class={styles.description}>
          <p class="description" style="color: var(--color-white);">
            {t.expertosUsuarios.description}
          </p>
        </div>
        
        <MainButton 
          text={t.expertosUsuarios.buttonText}
          href="/nosotros"
        />
      </div>
    </div>
  </div>
</section>
